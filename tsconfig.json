{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "exclude": [
    "src/App.tsx",
    "src/main.tsx",
    "src/components/ExpensesTracker.tsx",
    "src/components/SavingsGoals.tsx",
    "src/components/DebtTracker.tsx",
    "src/components/StatsAndCalendar.tsx",
    "node_modules",
    "dist"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}